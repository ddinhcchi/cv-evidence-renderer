# Copy to .env for local dev — .env is gitignored.

# Default encoder when CLI is run without --encoder. One of:
#   auto | nvenc_h264 | nvenc_h265 | libx264 | libx265
CV_EVIDENCE_ENCODER=auto

# Default output directory for evidence clips
CV_EVIDENCE_OUTPUT_DIR=./evidence

# Default pre/post buffer for EvidenceRecorder (live mode), seconds
CV_EVIDENCE_PRE_BUFFER=5
CV_EVIDENCE_POST_BUFFER=10
